{
  "expo": {
    "name": "A sos com o Pai",
    "slug": "a-sos-com-o-pai",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F5F2EB",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asoscomopai.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F2EB"
      },
      "package": "com.asoscomopai.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "b1687403-70da-43d7-b4a5-fae511641df6"
      }
    },
    "owner": "leobernardes"
  }
}
