{
  "expo": {
    "name": "A sos com o Pai",
    "slug": "a-sos-com-o-pai",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F5F2EB",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asoscomopai.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F2EB"
      },
      "package": "com.asoscomopai.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/icons/icon-192.png",
      "name": "A Sós com o Pai",
      "shortName": "A Sós com o Pai",
      "description": "Seu espaço diário de oração, jejum e conexão com Deus.",
      "backgroundColor": "#0D1B3E",
      "themeColor": "#0D1B3E",
      "lang": "pt-BR",
      "bundler": "metro",
      "icons": [
        {
          "src": "./assets/icons/icon-192.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any maskable"
        },
        {
          "src": "./assets/icons/icon-512.png",
          "sizes": "512x512",
          "type": "image/png",
          "purpose": "any maskable"
        },
        {
          "src": "./assets/icons/icon-1024.png",
          "sizes": "1024x1024",
          "type": "image/png",
          "purpose": "any maskable"
        }
      ]
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "b1687403-70da-43d7-b4a5-fae511641df6"
      }
    },
    "owner": "leobernardes"
  }
}
